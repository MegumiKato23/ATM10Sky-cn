	quest.75CD4EE6A542D687.title: "铜蜜蜂",
	quest.761D21C6FBD13EE1.quest_subtitle: "给钻石蜜蜂喂食橄榄石",
	quest.761D21C6FBD13EE1.title: "橄榄石蜜蜂",
	quest.76E94639E90FEB4E.quest_desc: ["在未照明的区域放置一些空的&e高级蜂箱&r。到了夜晚，蜜蜂会随着时间推移搬进去。"],
	quest.76E94639E90FEB4E.quest_subtitle: "在黑暗中的空蜂窝里生成",
