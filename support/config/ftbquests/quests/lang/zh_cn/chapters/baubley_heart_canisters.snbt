	quest.29555A5CFB098858.quest_subtitle: "现在总算有进展了",
	quest.297289FD3DA90DB4.quest_desc: ["几乎每一种敌对生物都会掉落一个 &c微型红心&r。它们可在游戏早期用于提升生命值。"],
	quest.297289FD3DA90DB4.quest_subtitle: "别吃它！",
