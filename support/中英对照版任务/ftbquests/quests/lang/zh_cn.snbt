	quest.19E678E6EF9539DC.quest_desc: ["只是一个简单的传感器,会输出红石信号并有一个过滤槽.\\n&7[Just a simple sensor that outputs a restone signal and has one filter slot.]&f"]
	quest.1B173E7533E1171F.quest_desc: ["只是一个简单的流体收集器.\\n&7[Just a simple fluid collector.]&f"]
