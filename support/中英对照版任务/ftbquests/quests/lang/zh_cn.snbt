	quest.512396B331108BAF.quest_subtitle: "等级:&e5&7[Tier: 5]&f"
	quest.5151CDD8FCDE7A07.quest_desc: ["欢迎来到基础工具!\\n\\n是否曾拿到过从未见过或听说过的工具,并想知道它在其他工具中处于什么水平？那么这些任务就非常适合你!\\n\\n(剑按基础伤害排序,可以升级或用于获得更高伤害的剑不包括在内).\\n\\n所有镐和剑的 &a任务&f 都是可选的!\\n&7[Welcome to Basic Tools!\\n\\nEver get a tool you've never seen or heard of and wanted to know where it lies among other tools? Then these quests are perfect for you!\\n\\n(The swords are sorted by base damage, swords that can be upgraded or used to get more damage are not included).\\n\\nThe quests for all the pickaxes and swords are OPTIONAL!]&f"]
	quest.5151CDD8FCDE7A07.quest_subtitle: "所有工具&7[All The Tools]&f"
	quest.5151CDD8FCDE7A07.title: "基础工具!&7[Basic Tools!]&f"
	quest.51DBE688ED630DB1.quest_subtitle: "等级:&54&7[Tier: 4]&f"
	quest.54D3D6806C1F33F3.quest_subtitle: "&f5 &c&a攻击伤害&f&7[5 Attack Damage]&f"
	quest.55A9EB63F4964FCF.quest_subtitle: "&f7 &c&a攻击伤害&f&7[7 Attack Damage]&f"
	quest.57F47BA495B27F83.quest_desc: ["&9等级 1&r 采集等级是最低的镐等级,需要一把镐.任何镐都可以挖掘这些方块.等级 1 的物品包括石头、熔炉和 &a煤矿石&f.\\n&7[Tier 1 Harvest Level is the lowest pickaxe level, needing a pickaxe. Any pickaxe can mine these. Items that are Tier 1 would be like Stone, Furnace, and Coal Ore.]&f"]
	quest.57F47BA495B27F83.title: "&9采集等级 1&7[Harvest Tier 1]&f"
	quest.58DDD32F849940A0.quest_subtitle: "等级:&d6&7[Tier: 6]&f"
	quest.5A2908437EC43AC6.quest_subtitle: "等级:&54&7[Tier: 4]&f"
	quest.5A6670364ADE0858.quest_subtitle: "&f29 &c&a攻击伤害&f&7[29 Attack Damage]&f"
	quest.609D03E335CF32E2.quest_subtitle: "等级:&d6&7[Tier: 6]&f"
	quest.632E537DA0F45CC7.quest_subtitle: "等级:&d6&7[Tier: 6]&f"
	quest.6552E301C370D203.quest_subtitle: "&f7 &c&a攻击伤害&f&7[7 Attack Damage]&f"
	quest.6601450C63FEEE61.quest_desc: ["&b等级 3&r 是 &a铁镐&f 级别,可以挖掘大多数矿石,如钻石、绿宝石和金矿.\\n&7[Tier 3 is Iron Pickaxe level, it mines most ores like Diamond, Emerald, and Gold.]&f"]
	quest.6601450C63FEEE61.title: "&b采集等级 3&7[Harvest Tier 3]&f"
	quest.680ECE3D8DCDC515.quest_subtitle: "&f13 &c&a攻击伤害&f&7[13 Attack Damage]&f"
	quest.6EE68EEFE388CF8A.quest_subtitle: "&f4 &c&a攻击伤害&f&7[4 Attack Damage]&f"
	quest.6EFA73A4D01F0052.quest_subtitle: "&f7 &c&a攻击伤害&f&7[7 Attack Damage]&f"
