	quest.29A05589E96C0569.quest_subtitle: "等级:&54&7[Tier: 4]&f"
	quest.2A6753C806D2AF8D.quest_desc: ["造成的伤害远超你的需求!不过也有一些缺点.\\n&7[Does more damage than you would ever need! Does have some downsides though.]&f"]
	quest.2A6753C806D2AF8D.quest_subtitle: "&f∞ &c&a攻击伤害&f&7[∞ Attack Damage]&f"
