	quest.36B9D5A99E1AA85C.quest_subtitle: "&f8 &c&a攻击伤害&f&7[8 Attack Damage]&f"
	quest.3917DECAEF56A06A.quest_desc: ["&f等级 2&r 是石镐级别.几乎只用于挖掘铁质物品.\\n&7[Tier 2 is the stone pickaxe level. It's almost only for mining Iron items.]&f"]
	quest.3917DECAEF56A06A.title: "&f采集等级 2&7[Harvest Tier 2]&f"
