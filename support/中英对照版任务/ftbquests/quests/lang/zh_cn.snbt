	task.0C4BD16741E25837.title: "入门 &a神龙镐&f&7[Entry Draconic Pickaxes]&f"
	task.2363F64BEC430933.title: "&a石英剑&f&7[Quartz Swords]&f"
	task.2962DF63EE602AD6.title: "&d通用机械&f &a铁镐&f&7[Mekanism Iron Pickaxes]&f"
	task.485E17B9E80D5DFF.title: "&d神秘学&f 镐&7[Occultism Pickaxes]&f"
