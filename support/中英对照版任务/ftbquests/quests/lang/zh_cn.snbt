	quest.7338CA23B27B2AF8.quest_subtitle: "&f12 &c&a攻击伤害&f&7[12 Attack Damage]&f"
	quest.744AC6BD82FC2DEE.quest_subtitle: "&f36 &c&a攻击伤害&f&7[36 Attack Damage]&f"
	quest.79E30114ED8870EE.quest_subtitle: "&f7 &c&a攻击伤害&f&7[7 Attack Damage]&f"
