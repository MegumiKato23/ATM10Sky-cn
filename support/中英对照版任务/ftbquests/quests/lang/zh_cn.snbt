	quest.52B2ADE472707372.quest_subtitle: "金冠苹果 + 澳洲青苹&7[Golden Declious Apple + Granny Smith Apple]&f"
	quest.53292D808E8F5218.quest_subtitle: "黑刺李 + 幸运&7[Blackthorn + Luck]&f"
	quest.53BA0C64804ADD24.quest_subtitle: "柚子 + &a野樱桃&f&7[Pomelo + Wild Cherry]&f"
	quest.53BDD0459F7B1D60.quest_subtitle: "咖啡树 + 柚木&7[Coffea + Teak]&f"
	quest.543F00603790AD3E.quest_desc: ["&a原木剥皮机&f会使用放入机器内的斧头自动剥去原木的树皮.\\n&7[The (Log) Stripper strips Logs automatically using Axes put in the machine.]&f"]
	quest.543F00603790AD3E.quest_subtitle: "请别这样&7[Please don't]&f"
	quest.543F00603790AD3E.title: "剥皮&7[Stripping]&f"
	quest.54E7967B45B20F36.quest_subtitle: "枸骨 + &a紫色&f 紫薇&7[Holly + Purple Crepe Myrtle]&f"
	quest.5577F49A93ADB19C.quest_desc: ["&l&d林业&f&r 是 &l&d资源蜜蜂&f&r 的姐妹模组.\\n\\n为了获得不同的树木,你将需要授粉树叶.要获得授粉树叶,你需要花粉.而花粉需要蜜蜂.\\n\\n在树木附近开花的蜜蜂会自动为树叶授粉,或者你也可以在蜂箱中使用花粉筛网升级来自己获取和使用花粉!送你一个,免费!\\n&7[lProductive Trees is a sister Mod to lProductive Bees.\\n\\nIn order to get the different Trees you will need Pollinated Leaves. To get Pollinated Leaves you need Pollen. For Pollen you need Bees.\\n\\nBees flowering near the Trees will automatically Pollinate Leaves, or you can use a Pollen Sieve Upgrade in the Hive to get and use Pollen yourself! Have one on the house!]&f"]
	quest.5577F49A93ADB19C.title: "&d林业&f&7[Productive Trees]&f"
